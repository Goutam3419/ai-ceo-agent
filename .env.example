# Ye file sirf EXAMPLE hai - iski copy banao naam se ".env.local"
# aur usme apni ASLI values daalo. .env.local kabhi GitHub pe upload nahi hoti.

ANTHROPIC_API_KEY=sk-ant-yahan-apni-actual-key-daalo

# Admin panel ka password - jo bhi chaho rakh sakte ho, strong rakhna
ADMIN_PASSWORD=apna-secret-password-yahan

# GitHub - isse CEO Agent khud website ki files padh/edit kar payega
# Token banane ka tareeka README.md mein hai
GITHUB_TOKEN=ghp_yahan-apna-token-daalo
GITHUB_REPO=your-username/your-repo-name
GITHUB_BRANCH=main

# Rangoli (design tool) — Firebase Authentication ke liye
# Firebase Console (console.firebase.google.com) se milenge, README mein steps hain
NEXT_PUBLIC_FIREBASE_API_KEY=apna-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=apna-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=apna-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=apna-project.appspot.com
NEXT_PUBLIC_FIREBASE_APP_ID=apna-app-id

# CEO Memory & Task Manager (Milestone 2) — Firebase Admin SDK
# Ye alag hai upar wali public keys se — ye SERVER-SIDE ONLY hai,
# CEO Agent ki memory/tasks store karne ke liye. Kabhi client mein
# expose nahi hoti. README mein steps hain isse kaise banaye.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
