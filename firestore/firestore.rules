// FIRESTORE SECURITY RULES
// =========================
// Deploy this via Firebase Console → Firestore Database → Rules
// (this file is NOT automatically picked up by Vercel/Next.js —
// it must be pasted into the Firebase Console manually, or deployed
// with the Firebase CLI: `firebase deploy --only firestore:rules`)
//
// Scope: these rules ONLY govern the public/multi-tenant Firestore
// usage (Rangoli, future Website Builder, Marketplace). The private
// /admin owner console never talks to Firestore through the client
// SDK — any future owner-side Firestore access happens through
// server-side API routes using the Firebase Admin SDK, which bypasses
// these rules entirely and is protected instead by the existing
// ADMIN_PASSWORD middleware.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerOf(resourceOwnerId) {
      return isSignedIn() && request.auth.uid == resourceOwnerId;
    }

    // Looks up the caller's role from their own users/{uid} doc.
    // Centralizing this here means adding a new elevated role later
    // (e.g. "moderator" reviewing marketplace items) only requires
    // changing this one function, not rewriting every match block.
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasElevatedRole() {
      return isSignedIn() && myRole() in ['staff', 'admin', 'owner'];
    }

    function isModeratorOrHigher() {
      return isSignedIn() && myRole() in ['moderator', 'staff', 'admin', 'owner'];
    }

    // ── users/{uid} ──────────────────────────────────────────
    // A user can only read/write their own profile document.
    // Note: users cannot set their own `role` field to an elevated
    // value — that field should only ever be changed server-side
    // (Admin SDK), a rule enforced once role-management ships.
    match /users/{uid} {
      allow read, write: if isOwnerOf(uid);
    }

    // ── projects/{projectId} ─────────────────────────────────
    // Owner has full access. Anyone can read a project that has
    // been published and not soft-deleted.
    match /projects/{projectId} {
      allow read: if (resource.data.status == 'published' && resource.data.deleted == false)
                   || isOwnerOf(resource.data.ownerId)
                   || hasElevatedRole();

      allow create: if isOwnerOf(request.resource.data.ownerId);

      allow update, delete: if isOwnerOf(resource.data.ownerId) || hasElevatedRole();

      // ── projects/{projectId}/pages/{pageId} ─────────────────
      // ownerId is denormalized onto each page doc so we don't need
      // an extra read of the parent project to check ownership.
      match /pages/{pageId} {
        allow read: if resource.data.deleted == false || isOwnerOf(resource.data.ownerId);
        allow write: if isOwnerOf(resource.data.ownerId) || hasElevatedRole();
        allow create: if isOwnerOf(request.resource.data.ownerId);
      }
    }

    // ── templates/{templateId} ───────────────────────────────
    // Publicly readable (template gallery), never shows soft-deleted
    // ones to normal users. Writes restricted to staff/admin — this
    // is the hook a future Creator Center will loosen, deliberately,
    // not by accident.
    match /templates/{templateId} {
      allow read: if resource.data.deleted == false || hasElevatedRole();
      allow write: if hasElevatedRole();
    }

    // ── assets/{assetId} ──────────────────────────────────────
    match /assets/{assetId} {
      allow read: if isOwnerOf(resource.data.ownerId) || hasElevatedRole();
      allow create: if isOwnerOf(request.resource.data.ownerId);
      allow update, delete: if isOwnerOf(resource.data.ownerId) || hasElevatedRole();
    }

    // ── marketplace/{itemId} ──────────────────────────────────
    // Publicly readable (browsing the marketplace), hidden if
    // soft-deleted or removed. Sellers manage their own listings;
    // moderators can change status (e.g. approve/reject/remove)
    // without needing full seller access.
    match /marketplace/{itemId} {
      allow read: if (resource.data.deleted == false && resource.data.status != 'removed')
                   || isOwnerOf(resource.data.sellerId)
                   || hasElevatedRole();
      allow create: if isOwnerOf(request.resource.data.sellerId);
      allow update: if isOwnerOf(resource.data.sellerId) || isModeratorOrHigher();
      allow delete: if isOwnerOf(resource.data.sellerId) || hasElevatedRole();
    }

    // ── orders/{orderId} ──────────────────────────────────────
    // CRITICAL: never allow client writes. Orders are only created
    // server-side after verifying a real payment (e.g. a Razorpay
    // webhook), once payment is integrated. Buyers can only read
    // their own order history.
    match /orders/{orderId} {
      allow read: if isOwnerOf(resource.data.buyerId) || hasElevatedRole();
      allow write: if false;
    }

    // ── notifications/{uid}/items/{notificationId} ───────────
    match /notifications/{uid}/items/{notificationId} {
      allow read, update, delete: if isOwnerOf(uid);
      allow create: if false; // notifications are created server-side only
    }

    // ── analytics/** ──────────────────────────────────────────
    // Owner-only aggregate data. Never touched by any client SDK —
    // written and read only via server-side Admin SDK. Deny everyone,
    // including elevated roles (this data doesn't belong in client
    // Firestore rules' trust boundary at all).
    match /analytics/{document=**} {
      allow read, write: if false;
    }

    // Default deny — anything not explicitly matched above is blocked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
